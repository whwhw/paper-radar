# LLM provider (OpenAI-compatible). Examples below.
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-opus-4-7

# Common alternatives — uncomment ONE set:
# OpenAI direct
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
#
# DeepSeek (Chinese-strong, ¥1-2/month for this project)
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
#
# Gemini Flash (free tier: 1500 req/day)
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_MODEL=gemini-2.0-flash
#
# Local Ollama (zero cost, requires Mac/server on; cannot use with cron)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:14b

TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=123456789
